        // Process bulk add
        function processBulkAdd() {
            const emailsText = document.getElementById('bulk-emails').value.trim();
            const role = document.getElementById('bulk-role').value;
            
            if (!emailsText || !role) {
                alert('Please enter emails and select a role');
                return;
            }
            
            const emails = emailsText.split(',').map(e => e.trim()).filter(e => e);
            let addedCount = 0;
            let duplicateCount = 0;
            
            emails.forEach(email => {
                // Validate email format
                if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
                    return;
                }
                
                // Check if exists
                if (allUsers.some(u => u.email.toLowerCase() === email.toLowerCase())) {
                    duplicateCount++;
                    return;
                }
                
                // Extract name from email (before @)
                const namePart = email.split('@')[0].replace(/[._-]/g, ' ');
                const name = namePart.split(' ').map(w => w.charAt(0).toUpperCase() + w.slice(1)).join(' ');
                
                const newUser = {
                    email: email,
                    name: name,
                    role: role,
                    createdAt: new Date().toISOString(),
                    status: 'active'
                };
                
                allUsers.push(newUser);
                addedCount++;
            });
            
            saveAllUsers();
            closeBulkAddModal();
            renderUsersTable();
            
            let msg = `Added ${addedCount} users`;
            if (duplicateCount > 0) msg += ` (${duplicateCount} duplicates skipped)`;
            alert(msg);
        }

