<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Revita Console 3.0 - Service Certification Training</title>
    <style>
        /* ============================================
           GLOBAL VARIABLES & RESET
           ============================================ */
        :root {
            --primary: #1B2A4A;
            --accent: #0098DB;
            --secondary: #00BFA5;
            --success: #4CAF50;
            --warn: #FF9800;
            --danger: #F44336;
            --bg: #F4F6F9;
            --light-gray: #E8EAED;
            --medium-gray: #9AA0A6;
            --dark-gray: #3C4043;
            --white: #FFFFFF;
            --shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
            --shadow-md: 0 4px 16px rgba(0, 0, 0, 0.12);
            --shadow-lg: 0 8px 24px rgba(0, 0, 0, 0.15);
            --border-radius: 12px;
            --transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        html, body {
            height: 100%;
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
            color: var(--dark-gray);
            background-color: var(--bg);
        }

        /* ============================================
           TYPOGRAPHY
           ============================================ */
        h1 { font-size: 2.5rem; font-weight: 700; line-height: 1.2; margin-bottom: 0.5rem; color: var(--primary); }
        h2 { font-size: 2rem; font-weight: 700; line-height: 1.3; margin-bottom: 0.75rem; color: var(--primary); }
        h3 { font-size: 1.5rem; font-weight: 600; line-height: 1.4; margin-bottom: 1rem; color: var(--primary); }
        h4 { font-size: 1.25rem; font-weight: 600; margin-bottom: 0.75rem; color: var(--primary); }
        h5 { font-size: 1rem; font-weight: 600; margin-bottom: 0.5rem; }
        h6 { font-size: 0.875rem; font-weight: 600; margin-bottom: 0.5rem; }

        p { line-height: 1.6; margin-bottom: 1rem; }
        a { color: var(--accent); text-decoration: none; transition: var(--transition); }
        a:hover { color: var(--primary); text-decoration: underline; }

        /* ============================================
           LAYOUT
           ============================================ */
        #app {
            display: flex;
            height: 100vh;
            overflow: hidden;
        }

        .sidebar {
            width: 280px;
            background-color: var(--primary);
            color: var(--white);
            display: flex;
            flex-direction: column;
            overflow-y: auto;
            transition: var(--transition);
            box-shadow: var(--shadow-md);
        }

        .sidebar.collapsed {
            margin-left: -280px;
        }

        .sidebar-header {
            padding: 1.5rem;
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
        }

        .sidebar-logo {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            margin-bottom: 0.5rem;
        }

        .sidebar-logo svg {
            width: 32px;
            height: 32px;
        }

        .sidebar-title {
            font-weight: 700;
            font-size: 0.875rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .sidebar-subtitle {
            font-size: 0.75rem;
            opacity: 0.8;
            margin-top: 0.25rem;
        }

        .sidebar-content {
            flex: 1;
            overflow-y: auto;
            padding: 1rem 0;
        }

        .sidebar-section {
            margin-bottom: 1.5rem;
        }

        .sidebar-section-title {
            font-size: 0.75rem;
            text-transform: uppercase;
            padding: 0.75rem 1.5rem;
            opacity: 0.6;
            letter-spacing: 0.5px;
        }

        .sidebar-nav-item {
            padding: 0.75rem 1.5rem;
            cursor: pointer;
            transition: var(--transition);
            border-left: 3px solid transparent;
            display: flex;
            align-items: center;
            gap: 0.75rem;
            font-size: 0.95rem;
        }

        .sidebar-nav-item:hover {
            background-color: rgba(255, 255, 255, 0.1);
        }

        .sidebar-nav-item.active {
            background-color: var(--accent);
            border-left-color: var(--secondary);
            font-weight: 600;
        }

        .sidebar-nav-icon {
            width: 20px;
            height: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.1rem;
        }

        .sidebar-footer {
            border-top: 1px solid rgba(255, 255, 255, 0.1);
            padding: 1rem;
        }

        .sidebar-footer-btn {
            width: 100%;
            padding: 0.75rem;
            background-color: rgba(255, 255, 255, 0.1);
            color: var(--white);
            border: none;
            border-radius: 6px;
            cursor: pointer;
            font-size: 0.875rem;
            transition: var(--transition);
            margin-bottom: 0.5rem;
        }

        .sidebar-footer-btn:hover {
            background-color: rgba(255, 255, 255, 0.2);
        }

        .main-container {
            flex: 1;
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }

        .topbar {
            background-color: var(--white);
            border-bottom: 1px solid var(--light-gray);
            padding: 1rem 2rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            box-shadow: var(--shadow);
            height: 80px;
        }

        .topbar-left {
            display: flex;
            align-items: center;
            gap: 1rem;
        }

        .hamburger {
            width: 40px;
            height: 40px;
            background: none;
            border: none;
            cursor: pointer;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            gap: 5px;
            display: none;
        }

        .hamburger span {
            width: 24px;
            height: 2px;
            background-color: var(--primary);
            transition: var(--transition);
        }

        .breadcrumbs {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            font-size: 0.95rem;
            color: var(--medium-gray);
        }

        .breadcrumbs a {
            color: var(--accent);
        }

        .breadcrumb-separator {
            color: var(--light-gray);
        }

        .topbar-right {
            display: flex;
            align-items: center;
            gap: 1.5rem;
        }

        .user-info {
            display: flex;
            align-items: center;
            gap: 0.75rem;
        }

        .user-avatar {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--accent), var(--secondary));
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--white);
            font-weight: 700;
            font-size: 1.1rem;
        }

        .user-details {
            display: none;
        }

        .user-name {
            font-weight: 600;
            font-size: 0.95rem;
        }

        .user-role {
            font-size: 0.8rem;
            color: var(--medium-gray);
        }

        .content-area {
            flex: 1;
            overflow-y: auto;
            padding: 2rem;
            position: relative;
        }

        .view {
            display: none;
            animation: fadeIn 0.3s ease-out;
        }

        .view.active {
            display: block;
        }

        @keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(10px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* ============================================
           CARDS & COMPONENTS
           ============================================ */
        .card {
            background-color: var(--white);
            border-radius: var(--border-radius);
            box-shadow: var(--shadow);
            padding: 1.5rem;
            transition: var(--transition);
        }

        .card:hover {
            box-shadow: var(--shadow-md);
            transform: translateY(-4px);
        }

        .card-clickable {
            cursor: pointer;
        }

        .badge-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
            gap: 1.5rem;
            margin: 2rem 0;
        }

        .badge-item {
            display: flex;
            flex-direction: column;
            align-items: center;
            text-align: center;
            gap: 0.75rem;
        }

        .badge-circle {
            width: 100px;
            height: 100px;
            border-radius: 50%;
            background-color: var(--accent);
            color: var(--white);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2.5rem;
            box-shadow: var(--shadow);
            transition: var(--transition);
            border: 2px solid transparent;
        }

        .badge-item.locked .badge-circle {
            background-color: var(--light-gray);
            color: var(--medium-gray);
            opacity: 0.6;
        }

        .badge-item.earned .badge-circle {
            background-color: var(--secondary);
            animation: badgeEarn 0.6s ease-out;
        }

        .superbadge-circle {
            width: 150px;
            height: 150px;
            border: 3px solid #FFD700;
            font-size: 3.5rem;
            box-shadow: 0 0 30px rgba(255, 215, 0, 0.5);
        }

        .superbadge-circle.earned {
            animation: superbadgeEarn 0.8s ease-out;
        }

        @keyframes badgeEarn {
            0% {
                transform: scale(0.8);
                opacity: 0;
            }
            50% {
                transform: scale(1.1);
            }
            100% {
                transform: scale(1);
                opacity: 1;
            }
        }

        @keyframes superbadgeEarn {
            0% {
                transform: scale(0);
                opacity: 0;
                filter: hue-rotate(0deg);
            }
            50% {
                transform: scale(1.15);
                filter: hue-rotate(20deg);
            }
            100% {
                transform: scale(1);
                opacity: 1;
                filter: hue-rotate(0deg);
            }
        }

        .badge-name {
            font-weight: 600;
            font-size: 0.9rem;
            color: var(--primary);
        }

        .badge-item.locked .badge-name {
            color: var(--medium-gray);
        }

        /* ============================================
           BUTTONS & INPUTS
           ============================================ */
        button, input[type="button"], input[type="submit"] {
            font-family: inherit;
            cursor: pointer;
            transition: var(--transition);
            border: none;
            border-radius: 6px;
            font-weight: 600;
            font-size: 0.95rem;
        }

        .btn {
            padding: 0.75rem 1.5rem;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
        }

        .btn-primary {
            background-color: var(--accent);
            color: var(--white);
        }

        .btn-primary:hover {
            background-color: #0085C2;
        }

        .btn-primary:disabled {
            background-color: var(--light-gray);
            color: var(--medium-gray);
            cursor: not-allowed;
        }

        .btn-secondary {
            background-color: var(--secondary);
            color: var(--white);
        }

        .btn-secondary:hover {
            background-color: #0AA394;
        }

        .btn-success {
            background-color: var(--success);
            color: var(--white);
        }

        .btn-success:hover {
            background-color: #45A049;
        }

        .btn-outline {
            background-color: transparent;
            color: var(--accent);
            border: 2px solid var(--accent);
        }

        .btn-outline:hover {
            background-color: var(--accent);
            color: var(--white);
        }

        .btn-block {
            width: 100%;
        }

        .btn-lg {
            padding: 1rem 2rem;
            font-size: 1.1rem;
        }

        input[type="text"], input[type="email"], textarea, select {
            width: 100%;
            padding: 0.75rem;
            border: 1px solid var(--light-gray);
            border-radius: 6px;
            font-family: inherit;
            font-size: 0.95rem;
            transition: var(--transition);
        }

        input[type="text"]:focus, input[type="email"]:focus, textarea:focus, select:focus {
            outline: none;
            border-color: var(--accent);
            box-shadow: 0 0 0 3px rgba(0, 152, 219, 0.1);
        }

        /* ============================================
           PROGRESS & INDICATORS
           ============================================ */
        .progress-bar {
            width: 100%;
            height: 8px;
            background-color: var(--light-gray);
            border-radius: 4px;
            overflow: hidden;
            margin-bottom: 0.75rem;
        }

        .progress-fill {
            height: 100%;
            background: linear-gradient(90deg, var(--accent), var(--secondary));
            transition: width 0.4s ease-out;
        }

        .progress-text {
            display: flex;
            justify-content: space-between;
            align-items: center;
            font-size: 0.85rem;
            color: var(--medium-gray);
        }

        .status-badge {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            padding: 0.4rem 0.8rem;
            border-radius: 20px;
            font-size: 0.75rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .status-not-started {
            background-color: var(--light-gray);
            color: var(--medium-gray);
        }

        .status-in-progress {
            background-color: rgba(255, 152, 0, 0.1);
            color: var(--warn);
        }

        .status-completed {
            background-color: rgba(76, 175, 80, 0.1);
            color: var(--success);
        }

        .status-locked {
            background-color: rgba(0, 0, 0, 0.05);
            color: var(--medium-gray);
        }

        /* ============================================
           CALLOUT BOXES
           ============================================ */
        .callout {
            border-left: 4px solid;
            padding: 1.25rem;
            margin: 1.5rem 0;
            border-radius: 4px;
            background-color: rgba(0, 0, 0, 0.02);
        }

        .callout.info {
            border-left-color: var(--accent);
            background-color: rgba(0, 152, 219, 0.05);
        }

        .callout.caution {
            border-left-color: var(--warn);
            background-color: rgba(255, 152, 0, 0.05);
        }

        .callout.warning {
            border-left-color: var(--danger);
            background-color: rgba(244, 67, 54, 0.05);
        }

        .callout.note {
            border-left-color: var(--success);
            background-color: rgba(76, 175, 80, 0.05);
        }

        .callout-title {
            font-weight: 700;
            margin-bottom: 0.5rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .callout.info .callout-title { color: var(--accent); }
        .callout.caution .callout-title { color: var(--warn); }
        .callout.warning .callout-title { color: var(--danger); }
        .callout.note .callout-title { color: var(--success); }

        /* ============================================
           TABLES
           ============================================ */
        .table-wrapper {
            overflow-x: auto;
            margin: 1.5rem 0;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            background-color: var(--white);
        }

        thead {
            background-color: var(--bg);
            position: sticky;
            top: 0;
            z-index: 10;
        }

        th {
            padding: 1rem;
            text-align: left;
            font-weight: 700;
            color: var(--primary);
            border-bottom: 2px solid var(--light-gray);
        }

        td {
            padding: 1rem;
            border-bottom: 1px solid var(--light-gray);
        }

        tbody tr:nth-child(even) {
            background-color: rgba(244, 246, 249, 0.5);
        }

        tbody tr:hover {
            background-color: rgba(0, 152, 219, 0.05);
        }

        /* ============================================
           QUIZ COMPONENTS
           ============================================ */
        .quiz-card {
            background-color: var(--white);
            border-radius: var(--border-radius);
            box-shadow: var(--shadow);
            padding: 2rem;
            max-width: 700px;
            margin: 0 auto;
        }

        .quiz-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 2rem;
            padding-bottom: 1.5rem;
            border-bottom: 2px solid var(--light-gray);
        }

        .quiz-progress {
            font-weight: 600;
            color: var(--accent);
            font-size: 0.95rem;
        }

        .quiz-timer {
            font-size: 0.9rem;
            color: var(--medium-gray);
        }

        .question-text {
            font-size: 1.3rem;
            font-weight: 600;
            margin-bottom: 1.5rem;
            color: var(--primary);
        }

        .question-options {
            display: flex;
            flex-direction: column;
            gap: 1rem;
            margin-bottom: 2rem;
        }

        .option {
            display: flex;
            align-items: center;
            padding: 1rem;
            border: 2px solid var(--light-gray);
            border-radius: 8px;
            cursor: pointer;
            transition: var(--transition);
            background-color: var(--white);
        }

        .option:hover {
            border-color: var(--accent);
            background-color: rgba(0, 152, 219, 0.05);
        }

        .option input {
            margin-right: 0.75rem;
            cursor: pointer;
            accent-color: var(--accent);
        }

        .option input[type="radio"], .option input[type="checkbox"] {
            width: 20px;
            height: 20px;
            cursor: pointer;
        }

        .option.selected {
            border-color: var(--accent);
            background-color: rgba(0, 152, 219, 0.1);
        }

        .option.correct {
            border-color: var(--success);
            background-color: rgba(76, 175, 80, 0.1);
        }

        .option.incorrect {
            border-color: var(--danger);
            background-color: rgba(244, 67, 54, 0.1);
        }

        .option-label {
            flex: 1;
            cursor: pointer;
        }

        .quiz-footer {
            display: flex;
            gap: 1rem;
            justify-content: space-between;
        }

        .quiz-nav {
            display: flex;
            gap: 0.5rem;
        }

        .quiz-nav button {
            padding: 0.75rem 1.5rem;
        }

        .quiz-results {
            text-align: center;
            padding: 2rem;
        }

        .results-icon {
            font-size: 4rem;
            margin-bottom: 1rem;
        }

        .results-score {
            font-size: 2.5rem;
            font-weight: 700;
            color: var(--primary);
            margin-bottom: 0.5rem;
        }

        .results-status {
            font-size: 1.3rem;
            font-weight: 600;
            margin-bottom: 1.5rem;
        }

        .results-status.pass {
            color: var(--success);
        }

        .results-status.fail {
            color: var(--danger);
        }

        .results-message {
            color: var(--medium-gray);
            margin-bottom: 2rem;
            line-height: 1.6;
        }

        .badge-earned {
            background-color: rgba(76, 175, 80, 0.1);
            border: 2px solid var(--success);
            border-radius: 12px;
            padding: 1.5rem;
            margin: 1.5rem 0;
            text-align: center;
        }

        .badge-earned-icon {
            font-size: 3rem;
            margin-bottom: 0.75rem;
        }

        .badge-earned-text {
            font-weight: 700;
            color: var(--success);
            margin-bottom: 0.25rem;
        }

        /* ============================================
           DASHBOARD
           ============================================ */
        .welcome-banner {
            background: linear-gradient(135deg, var(--primary), #2D3E5F);
            color: var(--white);
            padding: 3rem;
            border-radius: var(--border-radius);
            margin-bottom: 2rem;
        }

        .welcome-title {
            font-size: 2.2rem;
            font-weight: 700;
            margin-bottom: 0.5rem;
            color: var(--white);
        }

        .welcome-subtitle {
            font-size: 1.1rem;
            opacity: 0.95;
            margin-bottom: 1.5rem;
        }

        .welcome-audience {
            font-size: 0.95rem;
            opacity: 0.85;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 1.5rem;
            margin-bottom: 2rem;
        }

        .stat-card {
            background-color: var(--white);
            border-radius: var(--border-radius);
            padding: 1.5rem;
            box-shadow: var(--shadow);
            text-align: center;
        }

        .stat-value {
            font-size: 2.5rem;
            font-weight: 700;
            color: var(--accent);
            margin-bottom: 0.5rem;
        }

        .stat-label {
            color: var(--medium-gray);
            font-size: 0.95rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .modules-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
            gap: 2rem;
        }

        .module-card {
            background-color: var(--white);
            border-radius: var(--border-radius);
            overflow: hidden;
            box-shadow: var(--shadow);
            transition: var(--transition);
            display: flex;
            flex-direction: column;
            cursor: pointer;
        }

        .module-card:hover {
            box-shadow: var(--shadow-md);
            transform: translateY(-6px);
        }

        .module-header {
            background: linear-gradient(135deg, var(--accent), var(--secondary));
            color: var(--white);
            padding: 2rem;
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
        }

        .module-number {
            font-size: 2.5rem;
            font-weight: 700;
        }

        .module-header-right {
            display: flex;
            flex-direction: column;
            align-items: flex-end;
            gap: 0.5rem;
        }

        .module-badge {
            width: 60px;
            height: 60px;
            border-radius: 50%;
            background-color: rgba(255, 255, 255, 0.2);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.8rem;
            border: 2px solid rgba(255, 255, 255, 0.3);
        }

        .module-badge.earned {
            background-color: #FFD700;
            color: var(--primary);
            border-color: #FFC700;
        }

        .module-body {
            padding: 1.5rem;
            flex: 1;
            display: flex;
            flex-direction: column;
        }

        .module-title {
            font-size: 1.3rem;
            font-weight: 700;
            margin-bottom: 0.5rem;
            color: var(--primary);
        }

        .module-badge-name {
            font-size: 0.85rem;
            color: var(--medium-gray);
            margin-bottom: 1rem;
            font-weight: 600;
        }

        .module-meta {
            display: flex;
            gap: 1.5rem;
            font-size: 0.85rem;
            color: var(--medium-gray);
            margin-bottom: 1rem;
        }

        .module-meta-item {
            display: flex;
            align-items: center;
            gap: 0.4rem;
        }

        .module-progress {
            margin-top: auto;
        }

        /* ============================================
           MODULE DETAIL
           ============================================ */
        .module-detail-header {
            background: linear-gradient(135deg, var(--accent), var(--secondary));
            color: var(--white);
            padding: 2rem;
            border-radius: var(--border-radius);
            margin-bottom: 2rem;
        }

        .module-detail-title {
            font-size: 2rem;
