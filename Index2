                                        ${isChecked ? 'checked' : ''}
                                        onchange="selectAnswer(${quizQuestion}, ${idx}, '${question.type}')">
                                    <span class="option-label">${option}</span>
                                </label>
                            `;
                        }).join('')}
                    </div>

                    <div class="quiz-footer">
                        <div class="quiz-nav">
                            ${quizQuestion > 0 ? `<button class="btn btn-outline" onclick="previousQuestion()">← Previous</button>` : ''}
                            ${quizQuestion < module.quiz.length - 1 ? `<button class="btn btn-outline" onclick="nextQuestion()">Next →</button>` : ''}
                        </div>
                        ${quizQuestion === module.quiz.length - 1 ? `<button class="btn btn-primary btn-lg" onclick="submitQuiz()">📊 Submit Quiz</button>` : ''}
                    </div>
                </div>
            `;

            container.innerHTML = html;
        }

        function selectAnswer(questionIdx, optionIdx, type) {
            if (type === 'multi') {
                if (!quizAnswers[questionIdx]) {
                    quizAnswers[questionIdx] = [];
                }
                if (quizAnswers[questionIdx].includes(optionIdx)) {
                    quizAnswers[questionIdx] = quizAnswers[questionIdx].filter(i => i !== optionIdx);
                } else {
                    quizAnswers[questionIdx].push(optionIdx);
                }
            } else {
                quizAnswers[questionIdx] = [optionIdx];
            }
        }

        function nextQuestion() {
            const module = COURSE_DATA.modules.find(m => m.id === currentQuiz);
            if (quizQuestion < module.quiz.length - 1) {
                quizQuestion++;
                renderQuizQuestion();
            }
        }

        function previousQuestion() {
            if (quizQuestion > 0) {
                quizQuestion--;
                renderQuizQuestion();
            }
        }

        function submitQuiz() {
            const module = COURSE_DATA.modules.find(m => m.id === currentQuiz);
            let score = 0;

            module.quiz.forEach((q, idx) => {
                const userAnswers = quizAnswers[idx] || [];
                const correctAnswers = q.correct;

                if (JSON.stringify(userAnswers.sort()) === JSON.stringify(correctAnswers.sort())) {
                    score++;
                }
            });

            const percentage = (score / module.quiz.length) * 100;
            const passed = percentage >= (module.passThreshold * 100);

            const attemptsKey = `module-${currentQuiz}`;
            progress.attempts[attemptsKey] = (progress.attempts[attemptsKey] || 0) + 1;

            let scoresToStore = progress.quizScores[currentQuiz] || [];
            scoresToStore.push({ score, percentage, passed, date: new Date().toISOString() });
            progress.quizScores[currentQuiz] = scoresToStore;

            if (passed && !progress.badges.includes(currentQuiz)) {
                progress.badges.push(currentQuiz);
            }

            saveProgress();
            renderQuizResults(score, module.quiz.length, percentage, passed, module);
        }

        function renderQuizResults(score, total, percentage, passed, module) {
            const container = document.getElementById('quiz-content');
            const badgeEarned = progress.badges.includes(currentQuiz);

            let html = `
                <div class="quiz-card">
                    <div class="quiz-results">
                        <div class="results-icon">${passed ? '🎉' : '📝'}</div>
                        <div class="results-score">${Math.round(percentage)}%</div>
                        <div class="results-status ${passed ? 'pass' : 'fail'}">
                            ${passed ? '✓ PASSED' : '✗ Did Not Pass'}
                        </div>
                        <div class="results-message">
                            You scored <strong>${score} out of ${total}</strong> questions correctly.
                            ${module.passThreshold === 1.0 ? '<p style="margin-top: 0.5rem;">⚠️ This safety module requires 100% accuracy.</p>' : ''}
                        </div>

                        ${badgeEarned ? `
                            <div class="badge-earned">
                                <div class="badge-earned-icon">${module.badgeIcon}</div>
                                <div class="badge-earned-text">🏆 Badge Earned!</div>
                                <div style="font-size: 0.9rem; color: var(--success);">${module.badge}</div>
                            </div>
                        ` : ''}

                        <div style="margin-top: 2rem;">
                            <button class="btn btn-primary btn-lg btn-block" onclick="navigate('#module/${currentQuiz}')">Return to Module</button>
                            ${!passed && progress.attempts[`module-${currentQuiz}`] < 3 ? `
                                <button class="btn btn-outline btn-lg btn-block" style="margin-top: 0.5rem;" onclick="navigate('#quiz/${currentQuiz}')">Retake Quiz</button>
                            ` : ''}
                        </div>
                    </div>
                </div>
            `;

            container.innerHTML = html;

            if (badgeEarned && progress.badges.length === COURSE_DATA.modules.length) {
                setTimeout(() => {
                    showSuperbadgeAnimation();
                }, 500);
            }
        }

        function renderBadges() {
            const badgeGrid = document.getElementById('badges-grid');
            const superbadgeContainer = document.getElementById('superbadge-container');

            badgeGrid.innerHTML = '';
            COURSE_DATA.modules.forEach(module => {
                const isEarned = progress.badges.includes(module.id);
                const div = document.createElement('div');
                div.className = `badge-item ${isEarned ? 'earned' : 'locked'}`;
                div.innerHTML = `
                    <div class="badge-circle">${module.badgeIcon}</div>
                    <div class="badge-name">${module.badge}</div>
                `;
                badgeGrid.appendChild(div);
            });

            const superbadgeEarned = progress.badges.length === COURSE_DATA.modules.length;
            superbadgeContainer.innerHTML = `
                <div class="badge-item ${superbadgeEarned ? 'earned' : 'locked'}">
                    <div class="badge-circle superbadge-circle ${superbadgeEarned ? 'earned' : ''}">🏅</div>
                    <div class="badge-name" style="font-size: 1.1rem;">${COURSE_DATA.trail.superbadge}</div>
                </div>
            `;
        }

        function showSuperbadgeAnimation() {
            alert('🎉 Congratulations! You have earned the Tier 1 Service Certified Superbadge!');
        }

        function toggleSidebar() {
            document.getElementById('sidebar').classList.toggle('collapsed');
        }

        function toggleSettings() {
            document.getElementById('settings-modal').classList.toggle('active');
        }

        // Start the app
        init();
    

        // Initialize on page load
        document.addEventListener('DOMContentLoaded', function() {
            initUserSystem();
        });
        
        // Also initialize immediately if DOM is already ready
        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', function() {
                initUserSystem();
            });
        } else {
            initUserSystem();
        }

</script>
</body>
</html>
