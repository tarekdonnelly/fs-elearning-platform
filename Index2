    <script>

        // ============================================
        // USER MANAGEMENT SYSTEM
        // ============================================

        let currentUser = null;
        let allUsers = [];
        let isAdminMode = false;
        const ADMIN_EMAIL = 'tdonnelly@fractyl.com';
        const ADMIN_PASSWORD = 'FractylAdmin2026';

        // ============================================
        // PLATFORM URL CONFIGURATION
        // ============================================
        // This URL is used for invite links sent to new users.
        // Update this to your SharePoint or hosted URL.
        const DEFAULT_PLATFORM_URL = 'https://tarekdonnelly.github.io/fs-elearning-platform/';

        function getPlatformUrl() {
            // Check if admin has set a custom URL
            const customUrl = localStorage.getItem('fractyl_platform_url');
            if (customUrl) return customUrl;
            // If we're on a real web server (not a file://), use the current URL
            if (window.location.protocol === 'https:' || window.location.protocol === 'http:') {
                return window.location.href.split('?')[0].split('#')[0];
            }
            // Otherwise use the configured default
            return DEFAULT_PLATFORM_URL;
        }

        function savePlatformUrl(url) {
            localStorage.setItem('fractyl_platform_url', url);
        }

        // Simple hash function for email
        function hashEmail(email) {
            let hash = 0;
            for (let i = 0; i < email.length; i++) {
                const char = email.charCodeAt(i);
                hash = ((hash << 5) - hash) + char;
                hash = hash & hash; // Convert to 32bit integer
            }
            return Math.abs(hash).toString(36);
        }

        // Get progress key for current user
        function getProgressKey(email) {
            const hash = hashEmail(email);
            return `fractyl_progress_${hash}`;
        }

        // ============================================
        // PASSWORD HASHING (simple client-side hash)
        // ============================================
        async function hashPassword(password) {
            const encoder = new TextEncoder();
            const data = encoder.encode(password + 'fractyl_salt_2026');
            const hashBuffer = await crypto.subtle.digest('SHA-256', data);
            const hashArray = Array.from(new Uint8Array(hashBuffer));
            return hashArray.map(b => b.toString(16).padStart(2, '0')).join('');
        }

