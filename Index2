        async function handleChangePassword() {
            const msgDiv = document.getElementById('profile-message');
            msgDiv.className = 'profile-message';
            msgDiv.textContent = '';

            const currentPw = document.getElementById('profile-current-pw').value;
            const newPw = document.getElementById('profile-new-pw').value;
            const confirmPw = document.getElementById('profile-confirm-pw').value;

            if (!currentPw || !newPw || !confirmPw) {
                msgDiv.textContent = 'Please fill in all password fields.';
                msgDiv.className = 'profile-message error';
                return;
            }

            if (newPw.length < 8) {
                msgDiv.textContent = 'New password must be at least 8 characters.';
                msgDiv.className = 'profile-message error';
                return;
            }

            if (newPw !== confirmPw) {
                msgDiv.textContent = 'New passwords do not match.';
                msgDiv.className = 'profile-message error';
                return;
            }

            // Verify current password
            const currentHash = await hashPassword(currentPw);

            // Admin uses plain text password
            if (currentUser.email === ADMIN_EMAIL) {
                if (currentPw !== ADMIN_PASSWORD) {
                    msgDiv.textContent = 'Current password is incorrect.';
                    msgDiv.className = 'profile-message error';
                    return;
                }
                msgDiv.textContent = 'Admin password cannot be changed here.';
                msgDiv.className = 'profile-message error';
                return;
            }

            // Regular user
            loadAllUsers();
            const userIdx = allUsers.findIndex(u => u.email.toLowerCase() === currentUser.email.toLowerCase());
            if (userIdx === -1) return;

            if (allUsers[userIdx].passwordHash !== currentHash) {
                msgDiv.textContent = 'Current password is incorrect.';
                msgDiv.className = 'profile-message error';
                return;
            }

            const newHash = await hashPassword(newPw);
            allUsers[userIdx].passwordHash = newHash;
            saveAllUsers();

            // Update session
            currentUser.passwordHash = newHash;
            sessionStorage.setItem('fractyl_session', JSON.stringify(currentUser));

            msgDiv.textContent = 'Password updated successfully!';
            msgDiv.className = 'profile-message success';

            // Clear fields
            document.getElementById('profile-current-pw').value = '';
            document.getElementById('profile-new-pw').value = '';
            document.getElementById('profile-confirm-pw').value = '';
        }

